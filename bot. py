# ─────────────────────────────────────────────
# /start
# ─────────────────────────────────────────────
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    user = update.effective_user
    is_new = get_user(user.id) is None
    save_user(user.id, user.first_name, user.username)

    if is_new:
        await notify_new_user(context, user)

    keyboard = [
        [InlineKeyboardButton("🚀 Resume Banao (FREE)", callback_data="make_resume")],
        [InlineKeyboardButton("💎 Plans Dekho",         callback_data="show_plans")],
        [InlineKeyboardButton("ℹ️ Help",                callback_data="help")],
    ]
    if is_owner(user.id):
        keyboard.append(
            [InlineKeyboardButton("👑 Admin Panel", callback_data="admin_home")]
        )

    await update.message.reply_text(
        f"👋 *Namaste, {user.first_name}!*\n\n"
        "Main hoon *ResumeAI Bot* 🤖\n\n"
        "Main aapke liye banata hoon:\n"
        "📄 *Professional Resume* — AI-powered\n"
        "🖼️ *LinkedIn Banner* — Custom design\n"
        "💡 *Career Summary* — Job-ready content\n\n"
        "Neeche button dabao aur shuru karo! ⬇️",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard),
    )
    return ConversationHandler.END


# ─────────────────────────────────────────────
# Button Handler
# ─────────────────────────────────────────────
async def button_handler(
    update: Update, context: ContextTypes.DEFAULT_TYPE
) -> int:
    query = update.callback_query
    await query.answer()
    data = query.data

    # ── Admin ──
    if data.startswith("admin_"):
        await admin_callback(update, context)
        return ConversationHandler.END

    # ── Resume Banao ──
    if data == "make_resume":
        await query.edit_message_text(
            "✏️ *Step 1/4 — Aapka Naam*\n\n"
            "Apna poora naam likhein:\n"
            "_(e.g. Rahul Sharma)_",
            parse_mode="Markdown",
        )
        return NAME

    # ── Plans ──
    elif data == "show_plans":
        keyboard = [
            [InlineKeyboardButton("✅ Basic — ₹99",       callback_data="buy_basic")],
            [InlineKeyboardButton("⭐ Premium — ₹299",    callback_data="buy_premium")],
            [InlineKeyboardButton("🔥 Unlimited — ₹499",  callback_data="buy_unlimited")],
            [InlineKeyboardButton("⬅️ Back",              callback_data="back_home")],
        ]
        await query.edit_message_text(
            "💎 *Hamare Plans:*\n\n"
            "✅ *Basic — ₹99*\n"
            "  • 1 Resume + Banner\n"
            "  • PDF Download\n\n"
            "⭐ *Premium — ₹299*\n"
            "  • 5 Resumes + Banners\n"
            "  • Cover Letter bhi\n"
            "  • Priority Support\n\n"
            "🔥 *Unlimited — ₹499/month*\n"
            "  • Unlimited Resumes\n"
            "  • All Styles Unlocked\n"
            "  • LinkedIn Optimization\n\n"
            "_Pehla resume FREE hai!_ 🎁",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard),
        )
        return ConversationHandler.END

    # ── Buy Plan ──
    elif data.startswith("buy_"):
        plan_key = data.replace("buy_", "")
        plan = PLANS[plan_key]
        payment_link = create_payment_link(
            query.from_user.id, plan_key, plan["price"]
        )
        keyboard = [[
            InlineKeyboardButton(
                f"💳 ₹{plan['price']} Pay Karein", url=payment_link
            )
        ]]
        await query.edit_message_text(
            f"💳 *{plan['name']} Plan — ₹{plan['price']}*\n\n"
            "Payment ke baad plan auto-activate hoga ✅\n\n"
            "_Razorpay secure payment_ 🔒",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard),
        )
        return ConversationHandler.END

    # ── Help ──
    elif data == "help":
        await query.edit_message_text(
            "ℹ️ *Help & Commands:*\n\n"
            "/start — Bot shuru karo\n"
            "/resume — Naya resume banao\n"
            "/myresumes — Purane resumes dekho\n"
            "/plans — Plans aur pricing\n"
            "/support — Help chahiye?\n\n"
            "📧 Support: @YourSupportHandle",
            parse_mode="Markdown",
        )
        return ConversationHandler.END

    # ── Back Home ──
    elif data == "back_home":
        keyboard = [
            [InlineKeyboardButton("🚀 Resume Banao", callback_data="make_resume")],
            [InlineKeyboardButton("💎 Plans Dekho",  callback_data="show_plans")],
        ]
        await query.edit_message_text(
            "🏠 *Home*\n\nKya karna chahte hain?",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(keyboard),
        )
        return ConversationHandler.END

    # ── Style Select ──
    elif data.startswith("style_"):
        context.user_data["style"] = data.replace("style_", "")
        return await confirm_step(update, context)

    return ConversationHandler.END


