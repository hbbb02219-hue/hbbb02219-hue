async def confirm_step(
    update: Update, context: ContextTypes.DEFAULT_TYPE
) -> int:
    query = update.callback_query
    ud = context.user_data
    style_label = STYLES.get(ud.get("style", "modern"), "Modern")

    keyboard = [[
        InlineKeyboardButton("✅ Haan, Banao!", callback_data="generate_now"),
        InlineKeyboardButton("✏️ Edit Karo",   callback_data="restart"),
    ]]
    await query.edit_message_text(
        f"📋 *Aapki Details:*\n\n"
        f"👤 *Naam:* {ud.get('name')}\n"
        f"💼 *Job:* {ud.get('job')}\n"
        f"⚡ *Skills:* {ud.get('skills')}\n"
        f"📅 *Experience:* {ud.get('experience')}\n"
        f"🎨 *Style:* {style_label}\n\n"
        "Sab sahi hai?",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard),
    )
    return CONFIRM


# ─────────────────────────────────────────────
# Generate Resume
# ─────────────────────────────────────────────
async def generate_resume(
    update: Update, context: ContextTypes.DEFAULT_TYPE
) -> int:
    query = update.callback_query
    await query.answer()

    if query.data == "restart":
        await query.edit_message_text(
            "✏️ *Naam dobara likhein:*",
            parse_mode="Markdown"
        )
        return NAME

    await query.edit_message_text(
        "⏳ *AI aapka resume bana raha hai...*\n\n"
        "_Thoda wait karo!_ ✨",
        parse_mode="Markdown"
    )

    ud = context.user_data
    user = query.from_user

    resume_data = await generate_resume_content(
        name=ud["name"],
        job=ud["job"],
        skills=ud["skills"],
        experience=ud["experience"],
        style=ud.get("style", "modern"),
    )

    banner_text = await generate_banner_text(
        name=ud["name"],
        job=ud["job"],
        tagline=resume_data.get("bannerTagline", "Building Tomorrow Today"),
    )

    save_resume(user.id, ud, resume_data)

    # Owner ko notify karo
    await notify_resume_generated(context, user, ud, resume_data)

    # Resume bhejo
    await query.edit_message_text(
        format_resume_message(ud, resume_data),
        parse_mode="Markdown"
    )

    # Banner bhejo
    keyboard = [[
        InlineKeyboardButton("🔄 Naya Resume",    callback_data="make_resume"),
        InlineKeyboardButton("💎 Premium Upgrade", callback_data="show_plans"),
    ]]
    await context.bot.send_message(
        chat_id=query.message.chat_id,
        text=banner_text,
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard),
    )

    return ConversationHandler.END


def format_resume_message(ud: dict, data: dict) -> str:
    skills_str = " • ".join(data.get("keySkills", []))
    exp = data.get("experience", [{}])[0]
    edu = data.get("education", {})
    return (
        f"✅ *Aapka Resume Tayyaar Hai!*\n"
        f"{'─' * 30}\n\n"
        f"👤 *{ud['name']}*\n"
        f"💼 _{ud['job']}_\n"
        f"🔗 _{data.get('linkedinHeadline', '')}_\n\n"
        f"📋 *Summary:*\n{data.get('summary', '')}\n\n"
        f"⚡ *Skills:*\n{skills_str}\n\n"
        f"💼 *Experience:*\n"
        f"• *{exp.get('role', '')}* @ {exp.get('company', '')}\n"
        f"  _{exp.get('duration', '')}_ — {exp.get('achievement', '')}\n\n"
        f"🎓 *Education:*\n"
        f"• {edu.get('degree', '')} — {edu.get('college', '')}\n\n"
        f"{'─' * 30}\n"
        f"_Premium mein PDF download available hai!_ 📄"
    )


